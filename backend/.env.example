# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# PostgreSQL (docker-compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kuro
DB_SSLMODE=disable

# Auth provider: ldap | oidc
AUTH_PROVIDER=ldap

# Entwicklung: temporäres Passwort (beliebiger Benutzername + dieses Passwort)
DEV_AUTH_PASSWORD=123456
AUTH_TOKEN_SECRET=change-me-in-production
AUTH_TOKEN_TTL_HOURS=8

# LDAP / Active Directory (Phase 1)
LDAP_URL=ldap://your-dc.example.local:389
LDAP_BASE_DN=DC=example,DC=local
LDAP_USER_FILTER=(sAMAccountName=%s)
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# Microsoft Entra ID / OIDC (Phase 2)
OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:3000/api/auth/callback
